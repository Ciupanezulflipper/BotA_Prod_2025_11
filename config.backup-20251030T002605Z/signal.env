# --- Evaluation windows (minutes, comma-separated) ---
EVAL_WINDOWS=30,60

# --- Fixed TP/SL in pips used for accuracy scoring (will expand later to ATR) ---
TP_PIPS=12
SL_PIPS=12

# --- Multi-source truth selection & tolerances ---
# Primary: LOCAL CSV (data/*) if fresh enough (<= 300 seconds)
# Fallbacks: Yahoo then Finnhub (only if enabled and token present)
MAX_LOCAL_AGE_SEC=300

# Tolerances in pips (used when sources disagree)
TOLERANCE_PIPS_MAJORS=0.5
TOLERANCE_PIPS_JPY=1.0
TOLERANCE_PIPS_XAU=1.5

# Enable/disable external truth sources
ENABLE_YAHOO=true
ENABLE_FINNHUB=false

# Finnhub token (optional, only used if ENABLE_FINNHUB=true)
FINNHUB_TOKEN=

# Optional Telegram compact notices for each evaluation (HIT/MISS)
# If left empty here, system will read from $HOME/BotA/.env
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
