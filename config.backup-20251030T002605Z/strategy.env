# ===============================
# Bot A — strategy.env (REQUIRED, full file)
# Last updated: 2025-10-30 (UTC)
# ===============================

# Directories
export ROOT_DIR="$HOME/BotA"
export LOG_DIR="$ROOT_DIR/logs"
export CACHE_DIR="$ROOT_DIR/cache"
export DATA_DIR="$ROOT_DIR/data"

# Core trading universe (comma-separated, NO spaces)
export PAIRS="EURUSD,GBPUSD"

# Timeframes to scan (comma-separated, NO spaces)
export TIMEFRAMES="H1,H4,D1"

# Quality gates / thresholds
export CONFIDENCE_MIN="70"      # 0-100
export RSI_SLOPE_MIN="0.5"      # abs slope
export SPREAD_MAX_PIPS="3.0"
export NEWS_BLACKOUT="false"

# Accuracy evaluation windows (mins)
export EVAL_WINDOWS="30,60"

# Price truth sources
export ENABLE_YAHOO="true"
export ENABLE_FINNHUB="false"   # set true only if FINNHUB_TOKEN present in $ROOT_DIR/.env
export ENABLE_STOOQ="true"

# Telegram notifications
export TELEGRAM_NOTIFY="true"   # tokens read from $ROOT_DIR/.env

# Runtime knobs
export FETCH_TIMEOUT_SEC="12"
export MAX_RETRIES="2"
export FRESHNESS_SEC="180"
