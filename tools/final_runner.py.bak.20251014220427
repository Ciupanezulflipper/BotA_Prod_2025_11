#!/usr/bin/env python3
from __future__ import annotations
import os, sys, json, math, time, argparse, requests
import datetime as dt
from typing import Dict, Tuple, Optional
import pandas as pd
import numpy as np

from BotA.tools.providers import get_ohlc

# ---------- indicators ----------
def ema(series, n: int):
    s = pd.Series(series, dtype=float)
    return s.ewm(span=n, adjust=False).mean()

def rsi(series, n: int = 14):
    s = pd.Series(series, dtype=float)
    delta = s.diff()
    up = delta.clip(lower=0)
    down = -delta.clip(upper=0)
    roll_up = ema(up, n)
    roll_down = ema(down, n)
    rs = roll_up / roll_down.replace(0, 1e-10)   # avoid div0
    out = 100 - (100 / (1 + rs))
    return out.ffill().fillna(50)                 # no look-ahead

def macd(series, fast: int = 12, slow: int = 26, signal: int = 9):
    s = pd.Series(series, dtype=float)
    fast_ema = ema(s, fast)
    slow_ema = ema(s, slow)
    m = fast_ema - slow_ema
    sig = ema(m, signal)
    hist = m - sig
    return m, sig, hist

def atr(df: pd.DataFrame, n: int = 14):
    h = df["high"].astype(float)
    l = df["low"].astype(float)
    c = df["close"].astype(float)
    prev_c = c.shift(1)
    tr = pd.concat([(h - l).abs(), (h - prev_c).abs(), (l - prev_c).abs()], axis=1).max(axis=1)
    # first row can be NaN — use a single bfill to seed EMA safely
    tr = tr.bfill(limit=1)
    return ema(tr, n)

# ---------- risk levels ----------
def compute_atr_based_levels(df: pd.DataFrame, entry: float, side: str) -> Tuple[Optional[float], Optional[float]]:
    try:
        val = float(atr(df, 14).iloc[-1])
        if not np.isfinite(val) or val <= 0:
            return None, None

        # sanity cap: max 5% of entry
        max_atr = entry * 0.05
        if val > max_atr:
            val = max_atr

        msl = float(os.getenv("ATR_SL_MULT", "1.5"))
        mtp = float(os.getenv("ATR_TP_MULT", "2.0"))

        if side == "BUY":
            sl = entry - msl * val
            tp = entry + mtp * val
        elif side == "SELL":
            sl = entry + msl * val
            tp = entry - mtp * val
        else:
            return None, None

        return round(sl, 5), round(tp, 5)
    except Exception:
        return None, None

# ---------- telegram ----------
def send_telegram_message(text: str) -> None:
    token = os.getenv("TELEGRAM_BOT_TOKEN")
    chat_id = os.getenv("TELEGRAM_CHAT_ID")
    if not token or not chat_id:
        print("⚠️ TELEGRAM creds missing; skipping send", file=sys.stderr)
        return
    url = f"https://api.telegram.org/bot{token}/sendMessage"
    payload = {"chat_id": chat_id, "text": text}
    try:
        r = requests.post(url, json=payload, timeout=15)
        r.raise_for_status()
        print("Telegram sent.")
    except Exception as e:
        print(f"Telegram send failed: {e}", file=sys.stderr)

def format_telegram(symbol, decision, entry, providers, votes, extras):
    emoji = "🟢" if decision == "BUY" else "🔴" if decision == "SELL" else "⚪"
    now_utc = dt.datetime.now(dt.timezone.utc).strftime("%Y-%m-%d %H:%M")
    lines = [
        f"{emoji} {symbol} | {decision}",
        f"⏰ {now_utc} UTC",
        f"📈 Entry: {round(float(entry),5)}",
    ]
    tp = extras.get("tp"); sl = extras.get("sl")
    if tp and sl:
        lines.append(f"🎯 TP: {tp} | 🛑 SL: {sl}")
        if decision == "BUY":
            risk = entry - sl
            reward = tp - entry
        elif decision == "SELL":
            risk = sl - entry
            reward = entry - tp
        else:
            risk = reward = 0
        rr = round(reward / risk, 2) if risk and risk > 0 else 0
        lines.append(f"⚖️ RR: 1:{rr}")
    provs = ", ".join(sorted(set(v for v in providers.values() if v)))
    lines.append(f"🗳️ Votes: {votes} | 📡 {provs}")
    if os.getenv("ENHANCED_MSG") == "1":
        lines.append(f"📊 {extras.get('score','')} | {extras.get('reason','')}")
    return "\n".join(lines)

# ---------- analyzer ----------
def analyze(symbol: str):
    if not isinstance(symbol, str) or not symbol.strip():
        raise ValueError(f"Invalid symbol: {symbol}")

    tfs = ("H1", "H4", "D1")
    need = {"H1": 120, "H4": 50, "D1": 100}
    data: Dict[str, pd.DataFrame] = {}
    providers: Dict[str, str] = {}
    votes: Dict[str, int] = {}

    for tf in tfs:
        try:
            rows, src = get_ohlc(symbol, tf, need[tf])
            if not rows:
                print(f"⚠️ {tf}: empty rows from {src}", file=sys.stderr); continue
            df = pd.DataFrame(rows)
            if df.empty or len(df) < 30:
                print(f"⚠️ {tf}: only {len(df)} bars (need 30+), skipping", file=sys.stderr); continue

            # ensure types
            for col in ("open", "high", "low", "close"):
                if col not in df.columns:
                    raise RuntimeError(f"{tf}: missing {col}")
                df[col] = df[col].astype(float)

            # indicators
            df["ema9"] = ema(df["close"], 9)
            df["ema21"] = ema(df["close"], 21)
            df["rsi14"] = rsi(df["close"], 14)
            _, _, hist = macd(df["close"])
            df["macd_hist"] = hist

            last = df.iloc[-1]
            ema_bull = last["ema9"] > last["ema21"]
            rsi_bull = last["rsi14"] > 50
            macd_bull = last["macd_hist"] > 0

            if ema_bull and rsi_bull and macd_bull:
                votes[tf] = 1
            elif (not ema_bull) and (last["rsi14"] < 50) and (last["macd_hist"] < 0):
                votes[tf] = -1
            else:
                votes[tf] = 0

            data[tf] = df
            providers[tf] = src
        except Exception as e:
            print(f"❌ {tf} failed: {type(e).__name__}: {e}", file=sys.stderr)

    if not data:
        raise RuntimeError("No usable data from any timeframe/provider")

    # Deterministic reference DF (D1 -> H4 -> H1)
    ref_df = None
    for key in ("D1", "H4", "H1"):
        df = data.get(key)
        if df is not None:
            ref_df = df
            break
    if ref_df is None:
        raise RuntimeError("No valid reference dataframe")

    # entry
    try:
        entry = float(ref_df["close"].iloc[-1])
        if not (0 < entry < 1e6):
            raise ValueError(f"Entry out of range: {entry}")
    except (ValueError, TypeError) as e:
        raise RuntimeError(f"Invalid entry price: {e}")

    # decision from votes
    total_vote = sum(votes.values())
    if total_vote >= 2:
        decision = "BUY"
    elif total_vote <= -2:
        decision = "SELL"
    else:
        decision = "NEUTRAL"

    sl, tp = compute_atr_based_levels(ref_df, entry, decision)
    extras = {
        "tp": tp, "sl": sl,
        "score": f"{sum(1 for v in votes.values() if v!=0)}/{len(votes)} TFs non-neutral",
        "reason": f"Vote total={total_vote} | map={votes}"
    }

    # NEUTRAL or no SL/TP => skip sending
    if decision == "NEUTRAL":
        print(f"⚪ {symbol}: vote={total_vote}, skipping (no strong conviction)", file=sys.stderr)
        return None, None
    if sl is None or tp is None:
        print(f"⚠️ {symbol}: {decision} but no SL/TP, aborting", file=sys.stderr)
        return None, None

    payload = {
        "symbol": symbol,
        "decision": decision,
        "entry": entry,
        "tp": tp,
        "sl": sl,
        "providers": providers,
        "votes": votes,
    }

    # preview (to stdout)
    now_hm = dt.datetime.now(dt.timezone.utc).strftime("%H:%M")
    print(f"*preview* UTC {now_hm} payload: {json.dumps(payload)}")
    return payload, format_telegram(symbol, decision, entry, providers, votes, extras)

# ---------- main ----------
def main():
    ap = argparse.ArgumentParser()
    ap.add_argument("--symbol", required=True)
    ap.add_argument("--dry", action="store_true", help="print JSON + preview, no Telegram")
    ap.add_argument("--send", action="store_true", help="send Telegram if actionable")
    args = ap.parse_args()

    result = analyze(args.symbol)
    if result == (None, None):
        print("No actionable signal, exiting.")
        return

    payload, text = result
    if args.dry:
        print(json.dumps(payload, indent=2))
    if args.send:
        send_telegram_message(text)

if __name__ == "__main__":
    main()
