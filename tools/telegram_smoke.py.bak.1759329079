#!/usr/bin/env python3
import os, sys, requests

def main():
    token = os.getenv("TELEGRAM_BOT_TOKEN", "").strip()
    chat  = os.getenv("TELEGRAM_CHAT_ID", "").strip()
    verify = os.getenv("VERIFY_SSL", "true").lower() in ("1","true","yes")

    if not token:
        print("FAIL: TELEGRAM_BOT_TOKEN is missing")
        sys.exit(1)
    if not chat:
        print("FAIL: TELEGRAM_CHAT_ID is missing")
        sys.exit(1)

    url = f"https://api.telegram.org/bot{token}/sendMessage"
    payload = {"chat_id": chat, "text": "BotA smoke test ✅"}
    try:
        r = requests.post(url, json=payload, timeout=15, verify=verify)
        if r.status_code == 200 and r.json().get("ok"):
            print("OK: sent")
            return
        print(f"FAIL: {r.status_code} {r.reason} • {r.text[:120]}")
    except requests.exceptions.SSLError as e:
        print(f"FAIL: SSL error • {e}")
    except Exception as e:
        print(f"FAIL: network error • {e}")

if __name__ == "__main__":
    main()
