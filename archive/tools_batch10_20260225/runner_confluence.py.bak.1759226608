import os, sys, argparse, logging, math
from typing import Dict, Any, Tuple
import requests
import numpy as np
import pandas as pd
from datetime import datetime, timezone

# --- make tools importable when run as a script ---
SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))
if SCRIPT_DIR not in sys.path:
    sys.path.insert(0, SCRIPT_DIR)

from .scoring_v2 import EnhancedScorer
from indicators_ext import _ema

LOG = logging.getLogger("runner")
logging.basicConfig(level=logging.INFO, format="%(asctime)s %(levelname)s:%(name)s: %(message)s")

# (rest of file is identical to the last version you pasted; omitted here for brevity)
