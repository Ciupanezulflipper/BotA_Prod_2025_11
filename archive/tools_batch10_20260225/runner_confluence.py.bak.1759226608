def tf_to_provider(tf: str) -> Tuple[str, str]:
    tf = tf.upper()
    m = {
        "M1":"1min","M5":"5min","M15":"15min","M30":"30min",
        "H1":"1h","H4":"4h","D1":"1day"
    }
    return m.get(tf, "15min"), {"M1":"1","M5":"5","M15":"15","M30":"30","H1":"60","H4":"240","D1":"D"}.get(tf,"15")

def norm_pair_for_td(pair: str) -> str:
    if len(pair) >= 6:
        return pair[:3] + "/" + pair[3:6]
    return pair

def fetch_twelvedata(pair: str, tf: str, rows: int = 200, apikey: str | None = None) -> pd.DataFrame:
    sym = norm_pair_for_td(pair)
    interval, _ = tf_to_provider(tf)
    url = "https://api.twelvedata.com/time_series"
    params = dict(symbol=sym, interval=interval, outputsize=str(rows), apikey=apikey or "", timezone="UTC", order="ASC")
    r = requests.get(url, params=params, timeout=12)
    r.raise_for_status()
    data = r.json()
    if "values" not in data:
        raise RuntimeError(f"TwelveData no 'values': {data.get('message', str(data))}")
    df = pd.DataFrame(data["values"])
    df = df.rename(columns={"datetime":"time"})
    for c in ("open","high","low","close"):
        df[c] = pd.to_numeric(df[c], errors="coerce")
    df = df.dropna().reset_index(drop=True)
    return df[["time","open","high","low","close"]]

def fetch_alphavantage(pair: str, tf: str, rows: int = 200, apikey: str | None = None) -> pd.DataFrame:
    from_sym = pair[:3]; to_sym = pair[3:6]
    interval, _int = tf_to_provider(tf)
    if interval.endswith("h") or interval.endswith("day"):
        interval = "15min"
    url = "https://www.alphavantage.co/query"
    params = dict(function="FX_INTRADAY", from_symbol=from_sym, to_symbol=to_sym, interval=interval, apikey=apikey or "", outputsize="compact")
    r = requests.get(url, params=params, timeout=15)
    r.raise_for_status()
    j = r.json()
    key = next((k for k in j.keys() if "Time Series" in k), None)
    if not key:
        raise RuntimeError(f"AlphaVantage error: {j}")
    ts = j[key]
    rows_list = []
    for t, v in ts.items():
        rows_list.append({"time": t, "open": float(v.get("1. open", "nan")), "high": float(v.get("2. high", "nan")),
                          "low": float(v.get("3. low", "nan")), "close": float(v.get("4. close", "nan"))})
    df = pd.DataFrame(rows_list).dropna()
    df["time"] = pd.to_datetime(df["time"])
    df = df.sort_values("time").tail(rows).reset_index(drop=True)
    df["time"] = df["time"].dt.strftime("%Y-%m-%d %H:%M:%S")
    return df[["time","open","high","low","close"]]

def fetch_series(pair: str, tf: str, rows: int = 200) -> pd.DataFrame:
    td_key = os.getenv("TWELVE_DATA_API_KEY","")
    av_key = os.getenv("ALPHA_VANTAGE_API_KEY","")
    errs = []
    if td_key:
        try:
            return fetch_twelvedata(pair, tf, rows, td_key)
        except Exception as e:
            errs.append(f"TD:{e}")
    if av_key:
        try:
            return fetch_alphavantage(pair, tf, rows, av_key)
        except Exception as e:
            errs.append(f"AV:{e}")
    raise RuntimeError("fetch failed: " + "; ".join(errs) if errs else "no provider keys")

def compute_rsi(close: np.ndarray, period: int = 14) -> np.ndarray:
    if len(close) < period+1: return np.array([])
    delta = np.diff(close, prepend=close[0])
    gain = np.where(delta>0, delta, 0.0)
    loss = np.where(delta<0, -delta, 0.0)
    roll_up = pd.Series(gain).ewm(alpha=1/period, adjust=False).mean().to_numpy()
    roll_dn = pd.Series(loss).ewm(alpha=1/period, adjust=False).mean().to_numpy()
    rs = np.divide(roll_up, np.where(roll_dn==0, np.nan, roll_dn))
    rsi = 100 - (100 / (1 + rs))
    return np.nan_to_num(rsi, nan=50.0)

def compute_adx(high: np.ndarray, low: np.ndarray, close: np.ndarray, period: int = 14) -> float:
    if len(close) < period*2: return 0.0
    up = high[1:] - high[:-1]
    dn = low[:-1] - low[1:]
    plus_dm  = np.where((up>dn) & (up>0), up, 0.0)
    minus_dm = np.where((dn>up) & (dn>0), dn, 0.0)
    tr1 = high[1:] - low[1:]; tr2 = np.abs(high[1:] - close[:-1]); tr3 = np.abs(low[1:] - close[:-1])
    tr = np.maximum(tr1, np.maximum(tr2, tr3))
    atr = pd.Series(tr).ewm(alpha=1/period, adjust=False).mean()
    plus_di  = 100 * pd.Series(plus_dm).ewm(alpha=1/period, adjust=False).mean() / atr
    minus_di = 100 * pd.Series(minus_dm).ewm(alpha=1/period, adjust=False).mean() / atr
    dx = 100 * np.abs(plus_di - minus_di) / (plus_di + minus_di)
    adx = float(dx.ewm(alpha=1/period, adjust=False).mean().iloc[-1])
    return 0.0 if math.isnan(adx) else adx

def compute_macd(close: np.ndarray, fast: int=12, slow: int=26, sig: int=9):
    if len(close) < slow + sig + 5: return 0.0,0.0,0.0
    ema_fast = pd.Series(close).ewm(span=fast, adjust=False).mean()
    ema_slow = pd.Series(close).ewm(span=slow, adjust=False).mean()
    macd = ema_fast - ema_slow
    signal = macd.ewm(span=sig, adjust=False).mean()
    hist = macd - signal
    return float(macd.iloc[-1]), float(signal.iloc[-1]), float(hist.iloc[-1])

def ema_signal(close: np.ndarray, fast: int=20, slow: int=50) -> int:
    if len(close) < slow+2: return 0
    e_fast = _ema(close, fast)
    e_slow = _ema(close, slow)
    if e_fast[-1] > e_slow[-1]: return 1
    if e_fast[-1] < e_slow[-1]: return -1
    return 0

def calc_base_score(rsi_v: float, adx_v: float, macd_abs: float, ema_sig: int) -> float:
    score = 0.0
    if rsi_v < 38 or rsi_v > 62: score += 0.3
    else: score += 0.1
    score += 0.3 if adx_v >= 14 else 0.1
    score += 0.2 if macd_abs >= float(os.getenv("MACD_MIN", "0.00015")) else 0.1
    score += 0.2 if ema_sig != 0 else 0.1
    return min(1.0, score)

def decide_direction(ema_sig: int, rsi_v: float) -> int:
    if ema_sig > 0 and rsi_v <= 62: return 1
    if ema_sig < 0 and rsi_v >= 38: return -1
    return 0

def run_once(pair: str, tf: str) -> Tuple[str, float]:
    df = fetch_series(pair, tf, rows=230)
    if df.empty:
        raise RuntimeError("Empty OHLC")
    o = df["open"].to_numpy(float)
    h = df["high"].to_numpy(float)
    l = df["low"].to_numpy(float)
    c = df["close"].to_numpy(float)

    rsi_series = compute_rsi(c, 14)
    rsi_v = float(rsi_series[-1]) if len(rsi_series) else 50.0
    adx_v = compute_adx(h, l, c, 14)
    macd_v, macd_sig, macd_hist = compute_macd(c)
    ema_sig = ema_signal(c, 20, 50)
    base = calc_base_score(rsi_v, adx_v, abs(macd_v), ema_sig)
    direction = decide_direction(ema_sig, rsi_v)

    try:
        h1 = fetch_series(pair, "H1", rows=120)["close"].to_numpy(float)
    except Exception:
        h1 = np.array([])

    config = {k:v for k,v in os.environ.items() if k.startswith(("CONF_","ATR_","MTF_","FIB_","SR_","PATTERN_","DIVERGENCE_","NEWS_","W_"))}
    scorer = EnhancedScorer(config)
    market = {
        "high": h, "low": l, "close": c, "open": o,
        "current_price": float(c[-1]),
        "rsi": rsi_series,
        "h1_prices": h1
    }
    res = scorer.calculate_enhanced_score(base, market, pair, direction)

    dir_txt = "BUY" if direction==1 else ("SELL" if direction==-1 else "FLAT")
    emoji = "🟢" if direction==1 else ("🔴" if direction==-1 else "⏸️")
    score = res.final_score
    line = (f"{emoji} {pair} {tf} • Score {score:.2f} | "
            f"RSI {rsi_v:.1f} | ADX {adx_v:.1f} | ΔMACD {macd_v:+.6f} | {dir_txt}")
    return line, score

def main():
    ap = argparse.ArgumentParser()
    ap.add_argument("--pair", default="EURUSD")
    ap.add_argument("--tf", default="M15")
    ap.add_argument("--force", action="store_true")
    ap.add_argument("--dry-run", default="false")
    args = ap.parse_args()
    try:
        line, score = run_once(args.pair, args.tf)
        print(line, flush=True)
    except Exception as e:
        print(f"⏸️ {args.pair} {args.tf} • Score 0.00 | ERROR {e}", flush=True)

if __name__ == "__main__":
    main()
