import os, sys, json, time, logging
import datetime as dt
from pathlib import Path

# --- safe Telegram send: only send when message has BUY or SELL and is not neutral ---
def _is_actionable(msg: str) -> bool:
    if not isinstance(msg, str): 
        return False
    m = msg.lower()
    if ('buy' in m or 'sell' in m) and ('no actionable' not in m and 'neutral' not in m):
        return True
    return False

def safe_send(msg: str) -> None:
    if _is_actionable(msg):
        safe_send(msg)
        print("Telegram sent.")
    else:
        print("No actionable signal.")
