# ===============================
# Bot A — strategy.env (required)
# Last updated: 2025-10-30 (UTC)
# ===============================

# --- Core trading universe (comma-separated, NO spaces) ---
PAIRS=EURUSD,GBPUSD

# --- Timeframes to scan (comma-separated, NO spaces) ---
TIMEFRAMES=H1,H4,D1

# --- Quality gates / thresholds ---
CONFIDENCE_MIN=70
RSI_SLOPE_MIN=0.5
SPREAD_MAX_PIPS=3.0
NEWS_BLACKOUT=false

# --- Accuracy evaluation windows (mins) ---
EVAL_WINDOWS=30,60

# --- Price truth sources ---
ENABLE_YAHOO=true
ENABLE_FINNHUB=false
ENABLE_STOOQ=true

# --- Telegram notifications ---
TELEGRAM_NOTIFY=true
# Tokens/IDs are read from $HOME/BotA/.env

# --- File/paths ---
ROOT_DIR="$HOME/BotA"
LOG_DIR="$HOME/BotA/logs"
CACHE_DIR="$HOME/BotA/cache"
DATA_DIR="$HOME/BotA/data"

# --- Runtime knobs ---
FETCH_TIMEOUT_SEC=12
MAX_RETRIES=2
FRESHNESS_SEC=180
