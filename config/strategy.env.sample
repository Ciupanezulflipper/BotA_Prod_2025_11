##############################
# BotA Strategy Config (.env)
# Copy to config/strategy.env and:  chmod 600 config/strategy.env
##############################

### CORE
MODE="prod"
MARKET_DEFAULT="forex"
SYMBOLS="EURUSD,XAUUSD,GBPUSD,USDJPY,NAS100,US30"
PRIMARY_TF="H1"
TIMEFRAMES="M15,H1,H4,D1"     # available TFs for analysis
STATE_DIR="state"
LOG_DIR="logs"

### TELEGRAM (placeholders)
TELEGRAM_CHAT_ID="123456789"
TELEGRAM_TOKEN="__SET_ME__"

### POLLING / CONTROLLER
LONG_POLL_TIMEOUT_SEC="30"
POLL_INTERVAL_SEC="2"
MAX_RETRIES="5"
OFFSET_FILE="$STATE_DIR/telegram.offset"

### ALERTS
ALERTS_ENABLE="true"
ALERT_INCLUDE_EXPLANATION="true"
ALERT_SCREENSHOT_ENABLE="true"     # mplfinance charts
ALERT_SCREENSHOT_TF="H1"
ALERT_PRIVATE_CHANNEL_ONLY="true"

### LOGGING
LOG_LEVEL="INFO"   # DEBUG|INFO|WARNING|ERROR
LOG_JSON="false"

### PERFORMANCE / SAFETY
CACHE_TTL_SEC="600"
RATE_LIMIT_REQ_PER_MIN="18"
SPREAD_MAX_PIPS="3"               # ignore signals if spread too high

### MARKET HOURS
MARKET_VALIDATE_OPEN="true"
MARKET_TZ="America/New_York"      # for FX session gates

### RISK
POSITION_SIZE_PCT="1.0"
DAILY_LOSS_LIMIT_PCT="3"
MAX_OPEN_TRADES="3"
MIN_CANDLE_BODY_PCT="50"          # confirmation candle body % of range
AVOID_NEUTRAL_RSI="true"          # block entries if RSI 45–55 unless strong confluence

################################
# CONFLUENCE (toggle everything)
################################

## EMA Trend filter
USE_EMA="true"
EMA_FAST="9"
EMA_SLOW="21"
EMA_TREND_ONLY="true"             # require price on correct EMA side

## RSI
USE_RSI="true"
RSI_PERIOD="14"
RSI_OB="70"
RSI_OS="30"
RSI_NEUTRAL_LOW="45"
RSI_NEUTRAL_HIGH="55"
RSI_EXIT_DIVERGENCE="true"

## MACD confirmation
USE_MACD="false"
MACD_FAST="12"
MACD_SLOW="26"
MACD_SIGNAL="9"
MACD_SAME_SIDE="true"             # histogram and signal agree with trade

## ADX trend strength
USE_ADX="false"
ADX_PERIOD="14"
ADX_MIN="20"

## ATR stop/take & regime guard
USE_ATR="true"
ATR_PERIOD="14"
ATR_SL_MULT="1.5"
ATR_TP_MULT="2.5"
ATR_TRAILING="false"

## Fibonacci zone check
USE_FIB="false"
FIB_LEVELS="0.236,0.382,0.5,0.618,0.786"
FIB_CONFLUENCE_TOLERANCE_PCT="0.15"   # distance allowance to a level

## Candlestick patterns
USE_CANDLE_PATTERNS="true"
PATTERN_LIST="hammer,inverted_hammer,engulfing,bullish_engulfing,bearish_engulfing,doji,shooting_star,pin_bar"

## Volume
USE_VOLUME_SMA="false"
VOL_SMA_PERIOD="20"
VOL_MIN_MULT="1.2"

## Ichimoku (optional)
USE_ICHIMOKU="false"

###############################
# MULTI-TIMEFRAME CONFLUENCE
###############################
MTF_ENABLE="true"
MTF_TFS="H1,H4,D1"
MTF_MIN_BULL="2"
MTF_MIN_BEAR="2"
MTF_WEIGHT_H1="1"
MTF_WEIGHT_H4="1"
MTF_WEIGHT_D1="2"
MTF_DECISION_RULE="weighted_majority"   # majority|weighted_majority|all

###############################
# NEWS / MACRO FILTERS
###############################
NEWS_ENABLE="false"                      # master news gate
NEWS_SOURCE="rss"                        # rss|marketaux|fxstreet (adapter later)
NEWS_SENTIMENT_ENABLE="false"
NEWS_SENTIMENT_MIN="-0.05"               # allow slightly negative/positive by default
NEWS_BLACKOUT_HIGHIMPACT_BEFORE_MIN="30"
NEWS_BLACKOUT_HIGHIMPACT_AFTER_MIN="30"
NEWS_COUNTRIES="US,EU,UK"
ECONOMIC_CALENDAR_ENABLE="false"

###############################
# STORAGE / REPORTING
###############################
CSV_LOG_ENABLE="true"
CSV_PATH="$LOG_DIR/signals.csv"
SHEETS_ENABLE="false"
SHEETS_GSHEET_ID=""

###############################
# HEALTH
###############################
WEB_HEALTH_ENABLE="true"
HEALTH_PORT="8000"

###############################
# BACKTEST (local)
###############################
BACKTEST_ENABLE="false"
